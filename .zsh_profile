zstyle ':omz:update' mode disabled

# zsh plugins
source ~/.zsh/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
source ~/.zsh/zsh-autosuggestions/zsh-autosuggestions.zsh

plugins=(zsh-autosuggestions)

# prompt
prompt_context () {
    prompt_segment black default "[$USER@$HOST]"
}

prompt_dir() {
  prompt_segment blue $CURRENT_FG '%3~'
}

# alias
alias ll='ls -lah'
alias vi=vim
alias clone='git clone --depth=1'
alias ip="ifconfig | grep 'inet ' | uniq"
alias ag='ag --color-match=36'

alias nt="sudo nginx -t"
alias nsr="sudo nginx -s reload"

alias -s gz='tar -xzvf'
alias -s tgz='tar -xzvf'
alias -s zip='unzip'
alias -s bz2='tar -xjvf'

alias rr="cargo run | bat -l rust"

# kubectl context switch via symlink: `kc <name>` links ~/.kube/<name>.yaml -> ~/.kube/config
kc() {
    local kube_dir="$HOME/.kube"
    local config="$kube_dir/config"
    if (( $# == 0 )); then
        local current=""
        [[ -L "$config" ]] && current="${$(readlink "$config"):t:r}"
        for f in "$kube_dir"/*.yaml(N); do
            local name="${f:t:r}"
            if [[ "$name" == "$current" ]]; then
                print -P "* %F{green}${name}%f"
            else
                print "  ${name}"
            fi
        done
        return
    fi
    local target="$kube_dir/$1.yaml"
    if [[ ! -f "$target" ]]; then
        print -u2 "kc: no such kubeconfig: $1"
        return 1
    fi
    ln -sf "$target" "$config" && print "switched to $1"
}
_kc() { compadd -- ${$(print -l $HOME/.kube/*.yaml(N:t:r))} }
compdef _kc kc 2>/dev/null

# git
alias grcb='git push origin $(git_current_branch):$(git_current_branch)'
alias grpush='git push origin HEAD:refs/for/$(git_current_branch)'
alias grbd='git push origin :'
alias gcpush='grcb && grpush'
alias gsha='git rev-parse --short=7 HEAD'
alias grld='git worktree list --porcelain | grep "^worktree " | grep -v "$(git rev-parse --show-toplevel)$" | sed "s/^worktree //" | xargs -I{} git worktree remove --force {} 2>/dev/null; git branch -a | grep -v remotes | grep -v main | grep -v master | grep -v "^[*+]" | xargs -n 1 git branch -D'

function update() {
	git add . && git commit -am "`curl -s https://whatthecommit.com/index.txt `" && git push origin $(git_current_branch)
}

# docker
function drm() {
    docker ps -a | grep 'Exited' | awk '{print $1}' | xargs docker rm
}
function drmi() {
    docker images -a | grep '<none>' | awk '{print $3}' | xargs docker rmi
}

function destroy() {
   current=`pwd`
   echo "delete $current..."
   cd ..
   /bin/rm -rf $current
}

# env
export LC_CTYPE="zh_CN.UTF-8"
export EDITOR="/bin/vim"

export GOPATH=$HOME/code/go
export GOBIN=$GOPATH/bin
export GO111MODULE=on

export PATH=$GOBIN:$GOROOT/bin:~/.cargo/bin:$PATH

# man page colors
export LESS_TERMCAP_mb=$'\E[01;31m'
export LESS_TERMCAP_md=$'\E[01;31m'
export LESS_TERMCAP_me=$'\E[0m'
export LESS_TERMCAP_se=$'\E[0m'
export LESS_TERMCAP_so=$'\E[01;44;33m'
export LESS_TERMCAP_ue=$'\E[0m'
export LESS_TERMCAP_us=$'\E[01;32m'

source ~/.zsh/.zsh_local

for module in `ls ~/.zsh/*.zsh`
do
	source $module
done
